@using System.Web.Optimization
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Kho Điện Thoại</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet">
  
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #ffffff;
            color: #1a1a2e;
        }

        /* Top Bar */
        .top-bar {
            background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 100%);
            color: white;
            padding: 10px 0;
            font-size: 0.9rem;
        }

        .top-bar a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
        }

        .top-bar a:hover {
            color: #FFD700;
        }

        /* Main Navbar */
        .main-navbar {
            background: white !important;
            box-shadow: 0 2px 20px rgba(0,0,0,0.08);
            padding: 15px 0 !important;
        }

        .main-navbar.sticky-top {
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .navbar-brand-modern {
            display: flex !important;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .logo-icon {
            width: 50px;
            height: 50px;
            border-radius: 15px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
        }

        .logo-text {
            display: flex;
            flex-direction: column;
        }

        .logo-main {
            font-size: 1.3rem;
            font-weight: 800;
            color: #1a1a2e;
            line-height: 1.2;
        }

        .logo-sub {
            font-size: 0.75rem;
            color: #667eea;
            font-weight: 600;
        }

        /* Navbar Links - IMPORTANT FIX */
        .main-navbar .navbar-nav {
            display: flex !important;
            flex-direction: row !important;
        }

        .main-navbar .navbar-nav .nav-item {
            display: block !important;
        }

        .main-navbar .navbar-nav .nav-link {
            color: #1a1a2e !important;
            font-weight: 600 !important;
            padding: 10px 20px !important;
            border-radius: 10px;
            transition: all 0.3s;
            display: flex !important;
            align-items: center;
            gap: 8px;
            white-space: nowrap;
        }

        .main-navbar .navbar-nav .nav-link:hover {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
            color: white !important;
        }

        .main-navbar .navbar-nav .nav-link i {
            font-size: 1rem;
        }

        /* Dropdown */
        .main-navbar .dropdown-menu {
            border: none;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            border-radius: 15px;
            padding: 10px;
            margin-top: 10px;
        }

        .main-navbar .dropdown-item {
            border-radius: 10px;
            padding: 10px 15px;
            transition: all 0.3s;
            color: #1a1a2e;
        }

        .main-navbar .dropdown-item:hover {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .main-navbar .dropdown-item i {
            margin-right: 10px;
            width: 20px;
        }

        /* Cart Icon */
        .cart-icon {
            position: relative;
            display: inline-flex !important;
            align-items: center;
            justify-content: center;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: #f8f9fa;
            color: #1a1a2e !important;
            text-decoration: none;
            font-size: 1.2rem;
            transition: all 0.3s;
        }

        .cart-icon:hover {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white !important;
        }

        .cart-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #f5576c;
            color: white;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 700;
            border: 2px solid white;
        }

        /* User Menu */
        .user-avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            margin-right: 8px;
        }

        /* Buttons */
        .btn-login, .btn-register {
            display: inline-flex !important;
            align-items: center;
            gap: 8px;
            padding: 10px 20px !important;
            border-radius: 25px;
            text-decoration: none !important;
            font-weight: 600;
            transition: all 0.3s;
            white-space: nowrap;
        }

        .btn-login {
            background: #f8f9fa !important;
            color: #1a1a2e !important;
        }

        .btn-login:hover {
            background: #e9ecef !important;
            color: #1a1a2e !important;
        }

        .btn-register {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
            color: white !important;
        }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
            color: white !important;
        }

        /* Mobile Menu */
        .navbar-toggler {
            border: 2px solid #667eea;
            padding: 8px 12px;
        }

        .navbar-toggler:focus {
            box-shadow: 0 0 0 0.25rem rgba(102, 126, 234, 0.25);
        }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba(102, 126, 234, 1)' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }

        /* Footer */
        .footer-modern {
            background: #1a1a2e;
            color: white;
            padding: 60px 0 30px;
            margin-top: 80px;
        }

        .footer-modern h5 {
            font-weight: 700;
            margin-bottom: 20px;
            color: white;
        }

        .footer-modern a {
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer-modern a:hover {
            color: white;
        }

        .footer-modern p {
            color: rgba(255, 255, 255, 0.8);
            line-height: 1.8;
        }

        .social-links-modern {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        .social-links-modern a {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .social-links-modern a:hover {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            transform: translateY(-3px);
        }

        .footer-bottom {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin-top: 40px;
            padding-top: 20px;
            text-align: center;
        }

        /* Alerts */
        .alert {
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
            border: none;
        }

        .alert i {
            margin-right: 10px;
        }

     
    </style>

    @RenderSection("styles", required: false)
</head>
<body>
    <!-- Top Bar -->
    <div class="top-bar">
        <div class="container text-center">
            <span><i class="fas fa-phone-alt"></i> Hotline: 0909 123 456</span>
            <span class="ms-3"><i class="fas fa-gift"></i> Miễn phí vận chuyển cho đơn hàng trên 1 triệu</span>
        </div>
    </div>

    <!-- Main Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light main-navbar sticky-top">
        <div class="container">
            <a class="navbar-brand-modern" href="@Url.Action("Index", "Home")">
                <div class="logo-icon">
                    <i class="fas fa-mobile-alt"></i>
                </div>
                <div class="logo-text">
                    <div class="logo-main">Kho Điện Thoại</div>
                    <div class="logo-sub">Chính Hãng - Giá Tốt</div>
                </div>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Home")">
                            <i class="fas fa-home"></i>
                            <span>Trang Chủ</span>
                        </a>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-th-large"></i>
                            <span>Danh Mục</span>
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item" href="@Url.Action("DanhMuc", "Home", new { id = "DM001" })">
                                    <i class="fab fa-apple"></i> iPhone
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("DanhMuc", "Home", new { id = "DM002" })">
                                    <i class="fab fa-android"></i> Samsung
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("DanhMuc", "Home", new { id = "DM003" })">
                                    <i class="fas fa-mobile-alt"></i> Oppo
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("DanhMuc", "Home", new { id = "DM004" })">
                                    <i class="fas fa-mobile-screen-button"></i> Vivo
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("DanhMuc", "Home", new { id = "DM005" })">
                                    <i class="fas fa-mobile"></i> Xiaomi
                                </a>
                            </li>
                        </ul>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("SanPham", "Home")">
                            <i class="fas fa-box-open"></i>
                            <span>Sản Phẩm</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("LienHe", "Home")">
                            <i class="fas fa-phone-alt"></i>
                            <span>Liên Hệ</span>
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    @if (Session["UserID"] != null)
                    {
                        <li class="nav-item me-2">
                            <a class="cart-icon" href="@Url.Action("Index", "Cart")">
                                <i class="fas fa-shopping-cart"></i>
                                <span class="cart-badge badge-notification">
                                    @(Session["CartCount"] ?? 0)
                                </span>
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <div class="user-avatar">
                                    @Session["UserName"].ToString().Substring(0, 1).ToUpper()
                                </div>
                                <span>@Session["UserName"]</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li class="dropdown-header">
                                    <strong>@Session["UserName"]</strong>
                                </li>
                                <li><hr class="dropdown-divider"></li>

                                @if (Session["UserRole"] != null && (Session["UserRole"].ToString() == "admin" || Session["UserRole"].ToString() == "quanly"))
                                {
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("Index", "Admin")">
                                            <i class="fas fa-tachometer-alt"></i> Dashboard Admin
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                }

                                <li>
                                    <a class="dropdown-item" href="@Url.Action("ThongTinCaNhan", "Account")">
                                        <i class="fas fa-user"></i> Thông tin cá nhân
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("DonHangCuaToi", "Account")">
                                        <i class="fas fa-shopping-bag"></i> Đơn hàng của tôi
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")">
                                        <i class="fas fa-sign-out-alt"></i> Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn-login me-2" href="@Url.Action("Login", "Account")">
                                <i class="fas fa-sign-in-alt"></i>
                                <span>Đăng nhập</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn-register" href="@Url.Action("Register", "Account")">
                                <i class="fas fa-user-plus"></i>
                                <span>Đăng ký</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Alert Messages -->
    <div class="container mt-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fas fa-check-circle"></i>
                <strong>Thành công!</strong> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fas fa-exclamation-circle"></i>
                <strong>Lỗi!</strong> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show">
                <i class="fas fa-exclamation-triangle"></i>
                <strong>Cảnh báo!</strong> @TempData["Warning"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>

    <!-- Main Content -->
    <div>
        @RenderBody()
    </div>

    <!-- Footer -->
    <footer class="footer-modern">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5><i class="fas fa-mobile-alt"></i> Kho Điện Thoại</h5>
                    <p>Hệ thống cửa hàng điện thoại uy tín hàng đầu Việt Nam. Chuyên cung cấp các dòng điện thoại chính hãng với giá tốt nhất.</p>
                    <div class="social-links-modern">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                        <a href="#"><i class="fab fa-tiktok"></i></a>
                    </div>
                </div>

                <div class="col-md-4">
                    <h5>Danh Mục</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a href="@Url.Action("DanhMuc", "Home", new { id = "DM001" })"><i class="fas fa-angle-right"></i> iPhone</a></li>
                        <li class="mb-2"><a href="@Url.Action("DanhMuc", "Home", new { id = "DM002" })"><i class="fas fa-angle-right"></i> Samsung</a></li>
                        <li class="mb-2"><a href="@Url.Action("DanhMuc", "Home", new { id = "DM003" })"><i class="fas fa-angle-right"></i> Oppo</a></li>
                        <li class="mb-2"><a href="@Url.Action("DanhMuc", "Home", new { id = "DM004" })"><i class="fas fa-angle-right"></i> Vivo</a></li>
                        <li class="mb-2"><a href="@Url.Action("DanhMuc", "Home", new { id = "DM005" })"><i class="fas fa-angle-right"></i> Xiaomi</a></li>
                    </ul>
                </div>

                <div class="col-md-4">
                    <h5>Liên Hệ</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="fas fa-map-marker-alt me-2"></i>
                            123 Đường ABC, Q. 1, TP. HCM
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-phone me-2"></i>
                            <a href="tel:0909123456">0909 123 456</a>
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-envelope me-2"></i>
                            <a href="mailto:info@khodienthoai.com">info@khodienthoai.com</a>
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-clock me-2"></i>
                            8:00 - 22:00 (Hàng ngày)
                        </li>
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                <p class="mb-0">&copy; @DateTime.Now.Year <strong>Kho Điện Thoại</strong>. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("scripts", required: false)
</body>
</html>