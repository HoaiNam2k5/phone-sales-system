    </div>

    <div class="hero-content-wrapper">
        <div class="container">
            <div class="hero-text-content">
                <div class="hero-badge-animated">
                    <span class="badge-icon">⚡</span>
                    <span>Siêu Khuyến Mãi 2024</span>
                </div>
                <h1 class="hero-title-large">
                    Kho Điện Thoại
                    <span class="gradient-text">Chính Hãng</span>
                </h1>
                <p class="hero-description">
                    Trải nghiệm công nghệ đỉnh cao với các dòng điện thoại mới nhất
                    <br>Giá tốt nhất thị trường - Bảo hành chính hãng 12 tháng
                </p>
                <div class="hero-cta-group">
                    <a href="@Url.Action("SanPham", "Home")" class="btn-hero-primary">
                        <span>Khám Phá Ngay</span>
                        <i class="fas fa-arrow-right"></i>
                    </a>
                    <a href="#featured-products" class="btn-hero-secondary">
                        <i class="fas fa-play-circle"></i>
                        <span>Xem Sản Phẩm</span>
                    </a>
                </div>
                <div class="hero-stats">
                    <div class="stat-item">
                        <h3>1000+</h3>
                        <p>Sản phẩm</p>
                    </div>
                    <div class="stat-item">
                        <h3>50K+</h3>
                        <p>Khách hàng</p>
                    </div>
                    <div class="stat-item">
                        <h3>98%</h3>
                        <p>Hài lòng</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Brands Slider -->
<section class="brands-section">
    <div class="container">
        <div class="brands-slider">
            <div class="brand-item">
                <i class="fab fa-apple"></i>
                <span>Apple</span>
            </div>
            <div class="brand-item">
                <i class="fab fa-android"></i>
                <span>Samsung</span>
            </div>
            <div class="brand-item">
                <i class="fas fa-mobile-alt"></i>
                <span>Xiaomi</span>
            </div>
            <div class="brand-item">
                <i class="fas fa-mobile"></i>
                <span>Oppo</span>
            </div>
            <div class="brand-item">
                <i class="fas fa-mobile-screen-button"></i>
                <span>Vivo</span>
            </div>
            <!-- Duplicate for infinite scroll effect -->
            <div class="brand-item">
                <i class="fab fa-apple"></i>
                <span>Apple</span>
            </div>
            <div class="brand-item">
                <i class="fab fa-android"></i>
                <span>Samsung</span>
            </div>
        </div>
    </div>
</section>

<!-- Hot Deals Carousel -->
<section class="hot-deals-section">
    <div class="container">
        <div class="section-header-modern">
            <span class="section-badge">🔥 Hot Deals</span>
            <h2 class="section-title-modern">Ưu Đãi Hôm Nay</h2>
            <p class="section-subtitle-modern">Giảm giá đến 50% - Số lượng có hạn</p>
        </div>

        <div id="dealsCarousel" class="carousel slide deals-carousel" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="deal-card deal-card-primary">
                                <div class="deal-badge">-40%</div>
                                <div class="deal-content">
                                    <h3>iPhone 15 Pro Max</h3>
                                    <p class="deal-description">Titan tự nhiên - Camera 48MP</p>
                                    <div class="deal-price">
                                        <span class="old-price">28.990.000đ</span>
                                        <span class="new-price">17.394.000đ</span>
                                    </div>
                                    <a href="@Url.Action("DanhMuc", "Home", new { id = "DM001" })" class="btn-deal">
                                        Mua Ngay <i class="fas fa-arrow-right"></i>
                                    </a>
                                </div>
                                <div class="deal-image">
                                    <img src="https://images.unsplash.com/photo-1695048133142-1a20484d2569?w=500" alt="iPhone 15 Pro Max">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="deal-card deal-card-secondary">
                                <div class="deal-badge">-35%</div>
                                <div class="deal-content">
                                    <h3>Samsung S24 Ultra</h3>
                                    <p class="deal-description">AI Phone - S Pen tích hợp</p>
                                    <div class="deal-price">
                                        <span class="old-price">26.990.000đ</span>
                                        <span class="new-price">17.543.500đ</span>
                                    </div>
                                    <a href="@Url.Action("DanhMuc", "Home", new { id = "DM002" })" class="btn-deal">
                                        Mua Ngay <i class="fas fa-arrow-right"></i>
                                    </a>
                                </div>
                                <div class="deal-image">
                                    <img src="https://images.unsplash.com/photo-1610945415295-d9bbf067e59c?w=500" alt="Samsung S24">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="carousel-item">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="deal-card deal-card-accent">
                                <div class="deal-badge">-30%</div>
                                <div class="deal-content">
                                    <h3>Xiaomi 14 Ultra</h3>
                                    <p class="deal-description">Leica Camera - Snapdragon 8 Gen 3</p>
                                    <div class="deal-price">
                                        <span class="old-price">22.990.000đ</span>
                                        <span class="new-price">16.093.000đ</span>
                                    </div>
                                    <a href="@Url.Action("DanhMuc", "Home", new { id = "DM005" })" class="btn-deal">
                                        Mua Ngay <i class="fas fa-arrow-right"></i>
                                    </a>
                                </div>
                                <div class="deal-image">
                                    <img src="https://images.unsplash.com/photo-1598327105666-5b89351aff97?w=500" alt="Xiaomi 14">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="deal-card deal-card-success">
                                <div class="deal-badge">-25%</div>
                                <div class="deal-content">
                                    <h3>Oppo Find X7</h3>
                                    <p class="deal-description">Hasselblad Camera - 120W Fast Charge</p>
                                    <div class="deal-price">
                                        <span class="old-price">19.990.000đ</span>
                                        <span class="new-price">14.992.500đ</span>
                                    </div>
                                    <a href="@Url.Action("DanhMuc", "Home", new { id = "DM003" })" class="btn-deal">
                                        Mua Ngay <i class="fas fa-arrow-right"></i>
                                    </a>
                                </div>
                                <div class="deal-image">
                                    <img src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=500" alt="Oppo">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#dealsCarousel" data-bs-slide="prev">
                <i class="fas fa-chevron-left"></i>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#dealsCarousel" data-bs-slide="next">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>
    </div>
</section>

<!-- Categories Grid -->
<section class="categories-section-modern">
    <div class="container">
        <div class="section-header-modern text-center">
            <span class="section-badge">📱 Danh Mục</span>
            <h2 class="section-title-modern">Khám Phá Theo Thương Hiệu</h2>
        </div>

        <div class="categories-grid-modern">
            @foreach (var dm in (ViewBag.DanhMuc as List<QL_Kho.Models.DANHMUC>) ?? new List<QL_Kho.Models.DANHMUC>())
            {
                <a href="@Url.Action("DanhMuc", "Home", new { id = dm.MaDM.Trim() })" class="category-card-modern">
                    <div class="category-icon-large">
                        @switch (dm.MaDM.Trim())
                        {
                            case "DM001":
                                <i class="fab fa-apple"></i>
                                break;
                            case "DM002":
                                <i class="fab fa-android"></i>
                                break;
                            case "DM003":
                                <i class="fas fa-mobile-alt"></i>
                                break;
                            case "DM004":
                                <i class="fas fa-mobile-screen-button"></i>
                                break;
                            case "DM005":
                                <i class="fas fa-mobile"></i>
                                break;
                            default:
                                <i class="fas fa-mobile-alt"></i>
                                break;
                        }
                    </div>
                    <h3 class="category-name-modern">@dm.TenDM</h3>
                    <div class="category-overlay"></div>
                </a>
            }
        </div>
    </div>
</section>

<!-- Featured Products -->
<section class="products-section-modern" id="featured-products">
    <div class="container">
        <div class="section-header-modern">
            <span class="section-badge">⭐ Featured</span>
            <h2 class="section-title-modern">Sản Phẩm Nổi Bật</h2>
            <p class="section-subtitle-modern">Những sản phẩm được yêu thích nhất</p>
            <a href="@Url.Action("SanPham", "Home")" class="btn-view-all-modern">
                Xem Tất Cả <i class="fas fa-arrow-right"></i>
            </a>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="products-grid-modern">
                @foreach (var item in Model.Take(8))
                {
                    <div class="product-card-modern">
                        <div class="product-image-container">
                            <a href="@Url.Action("ChiTiet", "Home", new { id = item.MaSP.Trim() })">
                                @if (!string.IsNullOrEmpty(item.HinhAnh))
                                {
                                    <img src="~/Content/images/@item.HinhAnh" class="product-img" alt="@item.TenSP"
                                         onerror="this.src='https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=400'">
                                }
                                else
                                {
                                    <img src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=400" class="product-img" alt="@item.TenSP">
                                }
                            </a>

                            @if (item.SoLuongTon <= 10)
                            {
                                <span class="product-badge-modern badge-hot">
                                    🔥 Sắp hết
                                </span>
                            }
                            else if (item.SoLuongTon > 50)
                            {
                                <span class="product-badge-modern badge-new">
                                    ✨ Còn nhiều
                                </span>
                            }

                            <div class="product-actions-hover">
                                <button onclick="addToCart('@item.MaSP')" class="btn-quick-action" title="Thêm vào giỏ">
                                    <i class="fas fa-shopping-cart"></i>
                                </button>
                                <a href="@Url.Action("ChiTiet", "Home", new { id = item.MaSP.Trim() })" class="btn-quick-action" title="Xem chi tiết">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </div>
                        </div>

                        <div class="product-info-modern">
                            <h3 class="product-title-modern">
                                <a href="@Url.Action("ChiTiet", "Home", new { id = item.MaSP.Trim() })">
                                    @item.TenSP
                                </a>
                            </h3>

                            <div class="product-rating">
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star-half-alt"></i>
                                <span>(4.5)</span>
                            </div>

                            <div class="product-price-modern">
                                <span class="price-current">@string.Format("{0:N0}", item.DonGia)đ</span>
                                <span class="price-stock">
                                    <i class="fas fa-box"></i> @item.SoLuongTon
                                </span>
                            </div>

                            @if (item.SoLuongTon > 0)
                            {
                                <button onclick="addToCart('@item.MaSP')" class="btn-add-cart-modern">
                                    <i class="fas fa-cart-plus"></i>
                                    Thêm vào giỏ
                                </button>
                            }
                            else
                            {
                                <button class="btn-out-stock-modern" disabled>
                                    <i class="fas fa-ban"></i>
                                    Hết hàng
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state-modern">
                <i class="fas fa-box-open"></i>
                <h3>Chưa có sản phẩm</h3>
                <p>Hiện tại chưa có sản phẩm nào. Vui lòng quay lại sau!</p>
            </div>
        }
    </div>
</section>

<!-- Why Choose Us -->
<section class="features-section-modern">
    <div class="container">
        <div class="section-header-modern text-center">
            <span class="section-badge">💎 Ưu Điểm</span>
            <h2 class="section-title-modern">Tại Sao Chọn Chúng Tôi</h2>
        </div>

        <div class="features-grid-modern">
            <div class="feature-card-modern">
                <div class="feature-icon-modern icon-shipping">
                    <i class="fas fa-shipping-fast"></i>
                </div>
                <h4>Giao Hàng Nhanh</h4>
                <p>Miễn phí vận chuyển cho đơn hàng trên 1 triệu đồng</p>
            </div>

            <div class="feature-card-modern">
                <div class="feature-icon-modern icon-warranty">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h4>Bảo Hành Chính Hãng</h4>
                <p>Bảo hành 12 tháng từ nhà sản xuất</p>
            </div>

            <div class="feature-card-modern">
                <div class="feature-icon-modern icon-return">
                    <i class="fas fa-undo-alt"></i>
                </div>
                <h4>Đổi Trả Dễ Dàng</h4>
                <p>Đổi trả trong 7 ngày nếu có lỗi từ nhà sản xuất</p>
            </div>

            <div class="feature-card-modern">
                <div class="feature-icon-modern icon-support">
                    <i class="fas fa-headset"></i>
                </div>
                <h4>Hỗ Trợ 24/7</h4>
                <p>Tư vấn nhiệt tình, chuyên nghiệp mọi lúc</p>
            </div>
        </div>
    </div>
</section>

<!-- Newsletter -->
<section class="newsletter-section">
    <div class="container">
        <div class="newsletter-card">
            <div class="newsletter-icon">
                <i class="fas fa-envelope"></i>
            </div>
            <div class="newsletter-content">
                <h3>Đăng Ký Nhận Tin</h3>
                <p>Nhận thông tin về sản phẩm mới và ưu đãi độc quyền</p>
            </div>
            <form class="newsletter-form">
                <input type="email" placeholder="Email của bạn..." required>
                <button type="submit">
                    <i class="fas fa-paper-plane"></i>
                    Đăng Ký
                </button>
            </form>
        </div>
    </div>
</section>

@section styles {
    <link href="~/Content/modern-home.css" rel="stylesheet" />

}

@section scripts {
    <script src="~/Scripts/modern-site.js"></script>
    <script src="~/Scripts/modern-home.js"></script>
    <script>
        function addToCart(maSP) {
            @if (Session["UserID"] == null)
            {
                <text>
                if (confirm('Bạn cần đăng nhập để thêm vào giỏ hàng. Chuyển đến trang đăng nhập?')) {
                    window.location.href = '@Url.Action("Login", "Account")';
                }
                return;
                </text>
            }

            $.ajax({
                url: '@Url.Action("AddToCart", "Cart")',
                type: 'POST',
                data: { maSP: maSP, soLuong: 1 },
                success: function (response) {
                    if (response.success) {
                        $('.badge-notification').text(response.cartCount);
                        showToast('Đã thêm vào giỏ hàng!', 'success');
                    } else {
                        showToast(response.message, 'error');
                    }
                },
                error: function () {
                    showToast('Có lỗi xảy ra. Vui lòng thử lại!', 'error');
                }
            });
        }

        function showToast(message, type) {
            const colors = {
                success: { bg: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)', icon: 'fa-check-circle' },
                error: { bg: 'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)', icon: 'fa-exclamation-circle' }
            };

            const config = colors[type];
            const toast = $(`
                <div class="toast-notification">
                    <div class="toast-icon">
                        <i class="fas ${config.icon}"></i>
                    </div>
                    <div class="toast-message">${message}</div>
                </div>
            `);

            toast.css('background', config.bg);
            $('body').append(toast);

            setTimeout(() => toast.addClass('show'), 100);
            setTimeout(() => {
                toast.removeClass('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }
    </script>
}