@model QL_Kho.Models.DANHMUC
@{
    ViewBag.Title = "Thêm danh mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-plus-circle text-primary"></i> Thêm danh mục mới
    </h1>
    <a href="@Url.Action("QuanLyDanhMuc", "Admin")" class="btn btn-secondary shadow-sm">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Thông tin danh mục</h6>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @using (Html.BeginForm("ThemDanhMuc", "Admin", FormMethod.Post, new { enctype = "multipart/form-data", @class = "needs-validation", novalidate = "novalidate" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                            @Html.TextBoxFor(m => m.TenDM, new { @class = "form-control", placeholder = "Nhập tên danh mục", required = "required" })
                            @Html.ValidationMessageFor(m => m.TenDM, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Hình ảnh</label>
                            <input type="file" name="HinhAnhFile" class="form-control" accept="image/*" id="imageInput">
                            <small class="form-text text-muted">Chọn hình đại diện cho danh mục</small>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Trạng thái</label>
                            @Html.DropDownListFor(m => m.TrangThai, new SelectList(new[] {
                                new { Value = "HoatDong", Text = "Hoạt động" },
                                new { Value = "KhongHoatDong", Text = "Không hoạt động" }
                            }, "Value", "Text", "HoatDong"), new { @class = "form-control" })
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold">Mô tả</label>
                            @Html.TextAreaFor(m => m.MoTa, new { @class = "form-control", rows = 4, placeholder = "Nhập mô tả về danh mục..." })
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <button type="submit" class="btn btn-primary btn-lg px-4">
                            <i class="fas fa-save"></i> Lưu danh mục
                        </button>
                        <a href="@Url.Action("QuanLyDanhMuc", "Admin" )" class="btn btn-secondary btn-lg px-4">
                            <i class="fas fa-times"></i> Hủy
                        </a>
                    </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Xem trước hình ảnh</h6>
                </div>
                <div class="card-body text-center">
                    <img id="imagePreview" src="https://via.placeholder.com/300x300? text=Preview" class="img-fluid rounded" style="max-height: 300px;">
                </div>
            </div>
        </div>
    </div>

    @section scripts {
        @Scripts.Render("~/bundles/jqueryval")
        <script>
        $('#imageInput').change(function() {
            const file = this. files[0];
            if (file) {
                const reader = new FileReader();
                reader. onload = function(e) {
                    $('#imagePreview'). attr('src', e.target. result);
                }
                reader.readAsDataURL(file);
            }
        });
        </script>
    }