@model QL_Kho.Models.SANPHAM
@{
    ViewBag.Title = "Thêm sản phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-plus-circle text-primary"></i> Thêm sản phẩm mới
    </h1>
    <a href="@Url.Action("QuanLySanPham", "Admin")" class="btn btn-secondary shadow-sm">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Thông tin sản phẩm</h6>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @using (Html.BeginForm("ThemSanPham", "Admin", FormMethod.Post, new { enctype = "multipart/form-data", @class = "needs-validation", novalidate = "novalidate" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                            @Html.TextBoxFor(m => m.TenSP, new { @class = "form-control", placeholder = "Nhập tên sản phẩm", required = "required" })
                            @Html.ValidationMessageFor(m => m.TenSP, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Danh mục <span class="text-danger">*</span></label>
                            @Html.DropDownListFor(m => m.MaDM, (SelectList)ViewBag.DanhMuc, "-- Chọn danh mục --", new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(m => m.MaDM, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Nhà cung cấp <span class="text-danger">*</span></label>
                            @Html.DropDownListFor(m => m.MaNCC, (SelectList)ViewBag.NhaCungCap, "-- Chọn nhà cung cấp --", new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(m => m.MaNCC, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Giá bán <span class="text-danger">*</span></label>
                            @Html.TextBoxFor(m => m.DonGia, new { @class = "form-control", type = "number", min = "0", step = "1000", placeholder = "0", required = "required" })
                            @Html.ValidationMessageFor(m => m.DonGia, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Số lượng tồn</label>
                            @Html.TextBoxFor(m => m.SoLuongTon, new { @class = "form-control", type = "number", min = "0", Value = "0" })
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-bold">Đơn vị tính</label>
                            @Html.TextBoxFor(m => m.DonViTinh, new { @class = "form-control", placeholder = "Chiếc, Hộp.. .", Value = "Chiếc" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Hình ảnh</label>
                            <input type="file" name="HinhAnhFile" class="form-control" accept="image/*" id="imageInput">
                            <small class="form-text text-muted">Chọn file ảnh (JPG, PNG, tối đa 2MB)</small>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Trạng thái</label>
                            @Html.DropDownListFor(m => m.TrangThai, new SelectList(new[] {
                                new { Value = "HoatDong", Text = "Hoạt động" },
                                new { Value = "KhongHoatDong", Text = "Không hoạt động" }
                            }, "Value", "Text", "HoatDong"), new { @class = "form-control" })
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold">Mô tả</label>
                            @Html.TextAreaFor(m => m.MoTa, new { @class = "form-control", rows = 4, placeholder = "Nhập mô tả chi tiết sản phẩm..." })
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <button type="submit" class="btn btn-primary btn-lg px-4">
                            <i class="fas fa-save"></i> Lưu sản phẩm
                        </button>
                        <a href="@Url.Action("QuanLySanPham", "Admin" )" class="btn btn-secondary btn-lg px-4">
                            <i class="fas fa-times"></i> Hủy
                        </a>
                    </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Xem trước hình ảnh</h6>
                </div>
                <div class="card-body text-center">
                    <img id="imagePreview" src="https://via.placeholder.com/300x300? text=Preview" class="img-fluid rounded" style="max-height: 300px;">
                </div>
            </div>

            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">
                        <i class="fas fa-info-circle"></i> Hướng dẫn
                    </h6>
                </div>
                <div class="card-body">
                    <ul class="mb-0">
                        <li>Tên sản phẩm nên rõ ràng, dễ hiểu</li>
                        <li>Chọn đúng danh mục và nhà cung cấp</li>
                        <li>Giá bán phải lớn hơn 0</li>
                        <li>Hình ảnh nên có kích thước 500x500px</li>
                        <li>Mô tả chi tiết giúp khách hàng hiểu rõ hơn</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    @section scripts {
        @Scripts.Render("~/bundles/jqueryval")
        <script>
        $(document). ready(function() {
            // Preview image
            $('#imageInput').change(function() {
                const file = this.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $('#imagePreview').attr('src', e.target.result);
                    }
                    reader.readAsDataURL(file);
                }
            });

            // Form validation
            (function() {
                'use strict'
                var forms = document.querySelectorAll('.needs-validation')
                Array.prototype.slice.call(forms). forEach(function(form) {
                    form.addEventListener('submit', function(event) {
                        if (! form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
            })()
        });
        </script>
    }