@model List<QL_Kho.Models.NHACUNGCAP>
@{
    ViewBag.Title = "Quản lý nhà cung cấp";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-truck text-primary"></i> Quản lý nhà cung cấp
    </h1>
    <a href="@Url.Action("ThemNhaCungCap", "Admin")" class="btn btn-primary shadow-sm">
        <i class="fas fa-plus fa-sm"></i> Thêm nhà cung cấp
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">
            Danh sách nhà cung cấp <span class="badge bg-primary">@Model.Count</span>
        </h6>
    </div>
    <div class="card-body">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fas fa-check-circle"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-bordered table-hover" id="dataTable">
                <thead class="table-light">
                    <tr>
                        <th>Mã NCC</th>
                        <th>Tên nhà cung cấp</th>
                        <th>Địa chỉ</th>
                        <th>SĐT</th>
                        <th>Email</th>
                        <th>Số SP</th>
                        <th>Trạng thái</th>
                        <th width="120">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.MaNCC</strong></td>
                                <td>@item.TenNCC</td>
                                <td>@item.DiaChi</td>
                                <td>@item.SDT</td>
                                <td>@item.Email</td>
                                <td>
                                    <span class="badge bg-info">
                                        @(item.SANPHAMs?.Count(sp => sp.TrangThai == "HoatDong") ??  0)
                                    </span>
                                </td>
                                <td>
                                    @if (item.TrangThai == "HoatDong")
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Không hoạt động</span>
                                    }
                                </td>
                                <td>
                                    <a href="@Url.Action("SuaNhaCungCap", "Admin", new { id = item.MaNCC.Trim() })"
                                       class="btn btn-sm btn-warning"
                                       title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button type="button"
                                            class="btn btn-sm btn-danger btn-delete"
                                            data-id="@item.MaNCC"
                                            data-name="@item.TenNCC"
                                            title="Xóa">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                                <p class="mb-0">Chưa có nhà cung cấp nào</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function() {
            $('#dataTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/vi.json"
                }
            });

            $('. btn-delete').click(function() {
                var maNCC = $(this).data('id');
                var tenNCC = $(this).data('name');

                if (confirm('Bạn có chắc muốn xóa nhà cung cấp "' + tenNCC + '"?\nLưu ý: Không thể xóa nếu còn sản phẩm đang hoạt động. ')) {
                    $. ajax({
                        url: '@Url.Action("XoaNhaCungCap", "Admin")',
                        type: 'POST',
                        data: { maNCC: maNCC },
                        success: function(result) {
                            if (result.success) {
                                alert(result.message);
                                location.reload();
                            } else {
                                alert(result. message);
                            }
                        },
                        error: function() {
                            alert('Có lỗi xảy ra! ');
                        }
                    });
                }
            });
        });
    </script>
}