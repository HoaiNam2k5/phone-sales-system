@model QL_Kho.Models.DANHMUC
@{
    ViewBag.Title = "Sửa danh mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-edit text-warning"></i> Sửa danh mục
    </h1>
    <a href="@Url.Action("QuanLyDanhMuc", "Admin")" class="btn btn-secondary shadow-sm">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3 bg-warning">
                <h6 class="m-0 font-weight-bold text-white">Thông tin: @Model.TenDM</h6>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @using (Html.BeginForm("SuaDanhMuc", "Admin", FormMethod.Post, new { enctype = "multipart/form-data", @class = "needs-validation", novalidate = "novalidate" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.MaDM)

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Mã danh mục</label>
                            @Html.TextBoxFor(m => m.MaDM, new { @class = "form-control bg-light", @readonly = "readonly" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Trạng thái</label>
                            @Html.DropDownListFor(m => m.TrangThai, new SelectList(new[] {
                                new { Value = "HoatDong", Text = "Hoạt động" },
                                new { Value = "KhongHoatDong", Text = "Không hoạt động" }
                            }, "Value", "Text"), new { @class = "form-control" })
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                            @Html.TextBoxFor(m => m.TenDM, new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(m => m.TenDM, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold">Hình ảnh hiện tại</label>
                            <div class="mb-2">
                                @if (!string.IsNullOrEmpty(Model.HinhAnh))
                                {
                                    <img src="@Url.Content("~/Content/images/" + Model.HinhAnh)"
                                         alt="@Model.TenDM"
                                         class="img-thumbnail"
                                         style="max-width: 150px; max-height: 150px;">
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có hình ảnh</span>
                                }
                            </div>
                            <input type="file" name="HinhAnhFile" class="form-control" accept="image/*" id="imageInput">
                            <small class="form-text text-muted">Chọn file mới để thay đổi</small>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-bold">Mô tả</label>
                            @Html.TextAreaFor(m => m.MoTa, new { @class = "form-control", rows = 4 })
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <button type="submit" class="btn btn-warning btn-lg px-4">
                            <i class="fas fa-save"></i> Cập nhật
                        </button>
                        <a href="@Url.Action("QuanLyDanhMuc", "Admin" )" class="btn btn-secondary btn-lg px-4">
                            <i class="fas fa-times"></i> Hủy
                        </a>
                    </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Xem trước</h6>
                </div>
                <div class="card-body text-center">
                    <img id="imagePreview"
                         src="@(! string.IsNullOrEmpty(Model.HinhAnh) ?  Url.Content("~/Content/images/" + Model.HinhAnh) : "https://via.placeholder.com/300")"
                         class="img-fluid rounded"
                         style="max-height: 300px;">
                </div>
            </div>
        </div>
    </div>

    @section scripts {
        @Scripts.Render("~/bundles/jqueryval")
        <script>
        $('#imageInput').change(function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    $('#imagePreview').attr('src', e.target.result);
                }
                reader.readAsDataURL(file);
            }
        });
        </script>
    }