@model QL_Kho.ViewModels.DoiMatKhauViewModel

@{
    ViewBag.Title = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-5">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-gradient text-white text-center py-4" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                <h3><i class="fas fa-key"></i> Đổi Mật Khẩu</h3>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @Html.ValidationSummary(false, "", new { @class = "alert alert-danger" })

                @using (Html.BeginForm("DoiMatKhau", "Account", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        @Html.LabelFor(m => m. MatKhauCu, new { @class = "form-label fw-bold" })
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            @Html.PasswordFor(m => m.MatKhauCu, new
                            {
                                @class = "form-control",
                                placeholder = "Nhập mật khẩu cũ",
                                required = "required",
                                id = "oldPassword"
                            })
                            <button class="btn btn-outline-secondary" type="button" id="toggleOldPassword">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        @Html.ValidationMessageFor(m => m.MatKhauCu, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.MatKhauMoi, new { @class = "form-label fw-bold" })
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            @Html.PasswordFor(m => m.MatKhauMoi, new
                            {
                                @class = "form-control",
                                placeholder = "Nhập mật khẩu mới (ít nhất 6 ký tự)",
                                required = "required",
                                minlength = "6",
                                id = "newPassword"
                            })
                            <button class="btn btn-outline-secondary" type="button" id="toggleNewPassword">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        @Html.ValidationMessageFor(m => m.MatKhauMoi, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-3">
                        @Html.LabelFor(m => m.XacNhanMatKhauMoi, new { @class = "form-label fw-bold" })
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-lock"></i></span>
                            @Html.PasswordFor(m => m.XacNhanMatKhauMoi, new
                            {
                                @class = "form-control",
                                placeholder = "Nhập lại mật khẩu mới",
                                required = "required",
                                id = "confirmPassword"
                            })
                            <button class="btn btn-outline-secondary" type="button" id="toggleConfirmPassword">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        @Html.ValidationMessageFor(m => m.XacNhanMatKhauMoi, "", new { @class = "text-danger small" })
                    </div>

                    <div class="d-grid gap-2 mb-3">
                        <button type="submit" class="btn btn-lg text-white" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                            <i class="fas fa-check-circle"></i> Đổi mật khẩu
                        </button>
                        <a href="@Url.Action("ThongTinCaNhan", "Account" )" class="btn btn-secondary btn-lg">
                            <i class="fas fa-times-circle"></i> Hủy
                        </a>
                    </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @section scripts {
        @Scripts.Render("~/bundles/jqueryval")
        <script>
            $(document).ready(function () {
                // Toggle password visibility
                function togglePassword(buttonId, fieldId) {
                    $(buttonId).click(function () {
                        const field = $(fieldId);
                        const icon = $(this).find('i');
                        const type = field.attr('type') === 'password' ? 'text' : 'password';
                        field.attr('type', type);
                        icon.toggleClass('fa-eye fa-eye-slash');
                    });
                }

                togglePassword('#toggleOldPassword', '#oldPassword');
                togglePassword('#toggleNewPassword', '#newPassword');
                togglePassword('#toggleConfirmPassword', '#confirmPassword');

                // Validation
                $('#confirmPassword').on('input', function () {
                    const newPass = $('#newPassword').val();
                    const confirmPass = $(this).val();

                    if (newPass !== confirmPass) {
                        this.setCustomValidity('Mật khẩu xác nhận không khớp');
                    } else {
                        this.setCustomValidity('');
                    }
                });

                (function () {
                    'use strict'
                    var forms = document.querySelectorAll('.needs-validation')
                    Array.prototype.slice.call(forms).forEach(function (form) {
                        form.addEventListener('submit', function (event) {
                            if (!form.checkValidity()) {
                                event.preventDefault()
                                event.stopPropagation()
                            }
                            form.classList.add('was-validated')
                        }, false)
                    })
                })()
            });
        </script>
    }